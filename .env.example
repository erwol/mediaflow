# Copy this file to .env and adjust paths for your machine.
# Docker Compose reads .env automatically — no export needed.

# Absolute paths to your media directories on the host.
# The same path is mounted inside the container, so the backend
# writes files to exactly the location you see on the host.
MOVIES_DIR=/home/pi/movies
TVSHOWS_DIR=/home/pi/tvshows

# Port to expose the frontend on (prod only). Default: 3005
# FRONTEND_PORT=3005

# --- Optional metadata enrichment ---
# TV shows are enriched via TVMaze automatically (free, no key needed).
# For movie metadata, get a free API key at https://www.themoviedb.org/settings/api
# and paste it here.  Leave blank to skip movie enrichment.
# TMDB_API_KEY=
